# ==================== APP ====================
APP_NAME=Matching Esportivo
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
API_PORT=8000
UVICORN_WORKERS=2
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==================== DATABASE ====================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=matching_db
DB_USER=matching_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ==================== REDIS ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ==================== SECURITY ====================
SECRET_KEY=CHANGE_ME_64_PLUS_RANDOM_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== MATCHING ====================
DEFAULT_PROXIMITY_RADIUS_KM=15
MAX_EVENTS_PER_SEARCH=50

# ==================== OPTIONAL DEV ====================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
